{
  "expo": {
    "name": "AI Nevoie",
    "slug": "ainevoie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ainevoie",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.ainevoie.nrb",
      "buildNumber": "1.0.0",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "AI Nevoie folosește locația pentru a seta adresa ta principală și pentru navigație corectă către client.",
        "LSApplicationQueriesSchemes": [
          "waze",
          "comgooglemaps"
        ]
      }
    },
    "android": {
      "package": "com.ainevoie.nrb",
      "versionCode": 4,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 1284,
          "resizeMode": "cover",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "AI Nevoie folosește locația pentru a seta adresa ta principală și pentru navigație corectă către client."
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "76005ab7-ce8f-429d-96d3-eb2b35972160"
      }
    },
    "owner": "shikatedo1"
  }
}
