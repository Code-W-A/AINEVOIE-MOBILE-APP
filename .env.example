# Firebase config for the real AInevoie development project.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=europe-west1

# Google Auth client IDs used by expo-auth-session.
EXPO_PUBLIC_GOOGLE_AUTH_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_AUTH_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_AUTH_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Sentry (Expo app runtime)
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_APP_ENV=preview
# Build-time secret for sourcemap upload (set in CI/EAS secrets, do not commit real value)
SENTRY_AUTH_TOKEN=

# Stripe (Expo app runtime). Secret keys are configured only in Firebase Functions secrets.
EXPO_PUBLIC_PAYMENT_DEMO_MODE=false
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
EXPO_PUBLIC_STRIPE_MERCHANT_IDENTIFIER=merchant.com.ainevoie.nrb

# Phone auth note:
# This React Native implementation uses Firebase JS SDK signInWithPhoneNumber.
# Keep Firebase Phone Authentication enabled and configure project-level
# reCAPTCHA Enterprise bot protection in Enforce mode, otherwise OTP requests
# will fail without a compatible ApplicationVerifier.
